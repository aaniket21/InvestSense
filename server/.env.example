# === InvestSense Server — Environment Variables ===
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Server
PORT=3001

# Google Gemini API (get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Financial Data — Alpha Vantage (get from https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News/Search — Tavily (get from https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here
